{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/guide.ts":           { "maxDuration": 60 },
    "api/guide-more.ts":      { "maxDuration": 60 },
    "api/safety.ts":          { "maxDuration": 30 },
    "api/story.ts":           { "maxDuration": 30 },
    "api/check.ts":           { "maxDuration": 30 },
    "api/create-checkout.ts": { "maxDuration": 15 },
    "api/billing-webhook.ts": { "maxDuration": 15 },
    "api/places.ts":          { "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ]
}
