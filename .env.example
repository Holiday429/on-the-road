# ── Firebase (client-side, safe to expose) ────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── AI (server-side ONLY — no VITE_ prefix) ──────────────────────────────────
# DeepSeek: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
# Tavily (optional web search context): https://app.tavily.com/
TAVILY_API_KEY=
# Unsplash (optional card photos): https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY=

# ── Google Places (server-side ONLY — proxied via /api/places) ───────────────
# Used by Nomad place search/details/photos. NEVER expose this to the browser;
# the proxy keeps it server-side. Restrict the key to the Places API in GCP.
GOOGLE_PLACES_KEY=

# ── Google Maps Embed (client-side — safe IF referrer-locked) ────────────────
# Only the interactive map iframe in Nomad uses this. The embed API can't be
# proxied, so this key is in the page — lock it to your domain via an HTTP
# referrer restriction in GCP, and enable ONLY the Maps Embed API on it.
# Leave blank to fall back to the keyless maps.google.com embed.
VITE_MAPS_EMBED_KEY=

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# Minify the JSON to a single line before pasting.
FIREBASE_SERVICE_ACCOUNT=

# ── Lemon Squeezy payments ────────────────────────────────────────────────────
# API key: https://app.lemonsqueezy.com/settings/api
LEMON_SQUEEZY_API_KEY=
# Store ID: LS Dashboard → your store → Settings → numeric store id
LEMON_SQUEEZY_STORE_ID=
# Variant IDs: LS Dashboard → Products → your product → Variants → numeric id
LEMON_SQUEEZY_VARIANT_TRIP=
LEMON_SQUEEZY_VARIANT_LIFETIME=
# Webhook signing secret: LS Dashboard → Webhooks → Add endpoint → copy the secret
LEMON_SQUEEZY_WEBHOOK_SECRET=

# ── App URL (used for post-payment redirect) ──────────────────────────────────
APP_URL=https://easy-on-the-road.vercel.app
