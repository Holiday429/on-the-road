{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "lib": ["ES2022"],
    "types": ["node"],
    "skipLibCheck": true,
    "moduleResolution": "node10",
    "allowImportingTsExtensions": true,
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmit": true
  },
  "include": ["."]
}
