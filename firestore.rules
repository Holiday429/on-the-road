rules_version = '2';

// On the Road — collaboration-ready security rules.
// Trips are top-level (trips/{tripId}) and shared via a members map.
// Sub-collection access is gated by membership on the parent trip.
service cloud.firestore {
  match /databases/{database}/documents {

    /* ── Helpers ──────────────────────────────────────────────────────── */
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    // Membership read off the parent trip doc (used by sub-collection rules).
    function tripExists(tripId) {
      return exists(/databases/$(database)/documents/trips/$(tripId));
    }
    function tripData(tripId) {
      return get(/databases/$(database)/documents/trips/$(tripId)).data;
    }
    function subIsMember(tripId) {
      return signedIn() && tripExists(tripId) && uid() in tripData(tripId).memberUids;
    }
    function subCanEdit(tripId) {
      return subIsMember(tripId) && tripData(tripId).members[uid()] in ['owner', 'editor'];
    }

    // Membership read off THIS trip doc (update/delete operate on an existing
    // doc, so resource is always present there).
    function selfIsMember() {
      return signedIn() && uid() in resource.data.memberUids;
    }
    function selfIsOwner() {
      return selfIsMember() && resource.data.members[uid()] == 'owner';
    }
    function selfCanEdit() {
      return selfIsMember() && resource.data.members[uid()] in ['owner', 'editor'];
    }

    function inviteFor(token) {
      return get(/databases/$(database)/documents/tripInvites/$(token)).data;
    }

    // True if the caller is the owner of a given trip.
    function isTripOwner(tripId) {
      return signedIn()
        && tripExists(tripId)
        && tripData(tripId).members[uid()] == 'owner';
    }

    // A member (not the owner) removing ONLY themselves from the trip.
    function isSelfLeave() {
      let before = resource.data;
      let after = request.resource.data;
      let me = uid();
      return signedIn()
        && me in before.memberUids
        && before.members[me] != 'owner'
        && !(me in after.memberUids)
        && before.memberUids.hasOnly(after.memberUids.concat([me]))
        && after.ownerUid == before.ownerUid
        && after.diff(before).affectedKeys().hasOnly(['members', 'memberUids', 'updatedAt'])
        && before.members.diff(after.members).affectedKeys().hasOnly([me]);
    }

    // A signed-in user joining via email whitelist: their email must appear in
    // the trip's emailInvites map, and they add themselves as editor.
    function isEmailJoin() {
      let before = resource.data;
      let after = request.resource.data;
      let me = uid();
      let myEmail = request.auth.token.email;
      return signedIn()
        && myEmail != null
        && !(me in before.memberUids)
        && before.emailInvites != null
        && myEmail in before.emailInvites
        && before.emailInvites[myEmail] == 'editor'
        && after.memberUids.hasOnly(before.memberUids.concat([me]))
        && after.ownerUid == before.ownerUid
        && after.members[me] == 'editor'
        && after.diff(before).affectedKeys().hasOnly(['members', 'memberUids', 'emailInvites', 'updatedAt']);
    }

    // A signed-in user accepting an invite: adds only THEMSELVES, with a role
    // matching a live invite they pass as joinToken. tripId is passed in from
    // the match path (this helper lives outside the match block).
    function isSelfJoin(tripId) {
      let before = resource.data;
      let after = request.resource.data;
      let me = uid();
      return signedIn()
        && !(me in before.memberUids)
        && after.memberUids.hasOnly(before.memberUids.concat([me]))
        && after.ownerUid == before.ownerUid
        && after.diff(before).affectedKeys().hasOnly(['members', 'memberUids', 'joinToken', 'updatedAt'])
        && after.members.diff(before.members).affectedKeys().hasOnly([me])
        && exists(/databases/$(database)/documents/tripInvites/$(after.joinToken))
        && inviteFor(after.joinToken).tripId == tripId
        && inviteFor(after.joinToken).revoked == false
        && inviteFor(after.joinToken).role == after.members[me];
    }

    /* ── User profiles — private to each user ─────────────────────────── */
    match /users/{userId} {
      allow read, write: if signedIn() && uid() == userId;
      match /{document=**} {
        allow read, write: if signedIn() && uid() == userId;
      }
    }

    /* ── Trips ────────────────────────────────────────────────────────── */
    match /trips/{tripId} {
      // Single-doc reads: non-existent (probing is safe), members, or a trip
      // with public view enabled. Dual-read during migration: accept either the
      // new publicView.enabled or the legacy hasPublicView flag.
      allow get: if resource == null
        || (signedIn() && uid() in resource.data.memberUids)
        || (resource.data.publicView != null && resource.data.publicView.enabled == true)
        || resource.data.hasPublicView == true;

      // Queries: only the canonical "my trips" query is provable.
      allow list: if signedIn() && uid() in resource.data.memberUids;

      // Create: as yourself, sole owner at creation.
      allow create: if signedIn()
        && request.resource.data.ownerUid == uid()
        && request.resource.data.members[uid()] == 'owner'
        && uid() in request.resource.data.memberUids;

      // Update:
      //  - owner: full control (incl. member management)
      //  - editor: may not change members/memberUids/ownerUid
      //  - invite holder: self-join only (token link)
      //  - email-invited user: self-join via emailInvites whitelist
      //  - self-leave
      allow update: if selfIsOwner()
        || (selfCanEdit()
            && request.resource.data.members == resource.data.members
            && request.resource.data.memberUids == resource.data.memberUids
            && request.resource.data.ownerUid == resource.data.ownerUid)
        || isSelfJoin(tripId)
        || isEmailJoin()
        || isSelfLeave();

      allow delete: if selfIsOwner();

      // Sub-collections: read for members, or when public view is enabled AND
      // this sub-collection's name is in the published allow-list. Dual-read:
      // also honour the legacy coarse hasPublicView flag during migration.
      match /{sub}/{docId} {
        allow read: if subIsMember(tripId)
          || (tripData(tripId).publicView != null
              && tripData(tripId).publicView.enabled == true
              && (sub in tripData(tripId).publicView.collections))
          || tripData(tripId).hasPublicView == true;
        allow write: if subCanEdit(tripId);
      }
    }

    /* ── Trip invites ─────────────────────────────────────────────────── */
    match /tripInvites/{token} {
      // Viewer invite tokens must be readable without auth so guests can see
      // the trip name before deciding to enter. Editor invites stay auth-gated.
      allow read: if signedIn()
        || (resource != null && resource.data.role == 'viewer' && resource.data.revoked == false);
      allow create: if signedIn()
        && request.resource.data.createdByUid == uid()
        && subCanEdit(request.resource.data.tripId)
        && tripData(request.resource.data.tripId).members[uid()] == 'owner';
      allow update, delete: if signedIn()
        && tripExists(resource.data.tripId)
        && tripData(resource.data.tripId).members[uid()] == 'owner';
    }

    /* ── Trip access requests (edit-access approval flow) ─────────────────── */
    match /tripAccessRequests/{reqId} {
      // A signed-in user creates their OWN pending request for an existing trip.
      allow create: if signedIn()
        && request.resource.data.requesterUid == uid()
        && request.resource.data.status == 'pending'
        && tripExists(request.resource.data.tripId);

      // Read/list: the requester (their own) OR the trip owner. The owner-check
      // reads the trip doc (no owner field on the request), so owner-side
      // queries MUST be scoped by tripId for every matched doc to prove out.
      allow get, list: if signedIn()
        && (resource.data.requesterUid == uid()
            || isTripOwner(resource.data.tripId));

      // Update: only the trip owner, only flipping status (+ updatedAt). The
      // member is added on the trip doc via the owner's full update rights.
      allow update: if signedIn()
        && isTripOwner(resource.data.tripId)
        && request.resource.data.requesterUid == resource.data.requesterUid
        && request.resource.data.tripId == resource.data.tripId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);

      allow delete: if signedIn() && isTripOwner(resource.data.tripId);
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
