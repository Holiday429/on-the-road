rules_version = '2';

// On the Road — collaboration-ready security rules.
// Trips are top-level (trips/{tripId}) and shared via a members map.
// Sub-collection access is gated by membership on the parent trip.
service cloud.firestore {
  match /databases/{database}/documents {

    /* ── Helpers ──────────────────────────────────────────────────────── */
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function tripData(tripId) {
      return get(/databases/$(database)/documents/trips/$(tripId)).data;
    }

    function isMember(tripId) {
      return signedIn() && uid() in tripData(tripId).memberUids;
    }

    function roleOn(tripId) {
      return tripData(tripId).members[uid()];
    }

    function canEdit(tripId) {
      return isMember(tripId) && roleOn(tripId) in ['owner', 'editor'];
    }

    function isOwner(tripId) {
      return isMember(tripId) && roleOn(tripId) == 'owner';
    }

    // A signed-in user accepting an invite: the only membership change is
    // adding THEMSELVES, the rest of the trip doc is untouched, and the role
    // they grant themselves matches a valid (non-revoked) invite for this trip.
    function isSelfJoin(tripId) {
      let before = resource.data;
      let after = request.resource.data;
      let me = uid();
      return signedIn()
        && !(me in before.memberUids)
        && after.memberUids.hasAll(before.memberUids)
        && after.memberUids.hasOnly(before.memberUids.concat([me]))
        && after.ownerUid == before.ownerUid
        // Everything except members/memberUids/updatedAt must be unchanged.
        && after.diff(before).affectedKeys().hasOnly(['members', 'memberUids', 'updatedAt'])
        && validInviteGrants(tripId, after.members[me]);
    }

    // True if some invite doc authorises `role` for this trip. The client must
    // have created/holds the invite; we just confirm one exists and is live.
    function validInviteGrants(tripId, role) {
      return exists(/databases/$(database)/documents/tripInvites/$(request.resource.data.joinToken))
        && inviteFor(request.resource.data.joinToken).tripId == tripId
        && inviteFor(request.resource.data.joinToken).revoked == false
        && inviteFor(request.resource.data.joinToken).role == role;
    }

    function inviteFor(token) {
      return get(/databases/$(database)/documents/tripInvites/$(token)).data;
    }

    /* ── User profiles — private to each user ─────────────────────────── */
    match /users/{userId} {
      allow read, write: if signedIn() && uid() == userId;
      match /{document=**} {
        allow read, write: if signedIn() && uid() == userId;
      }
    }

    /* ── Trips ────────────────────────────────────────────────────────── */
    match /trips/{tripId} {
      allow read: if isMember(tripId);

      // Create: only as yourself, sole owner at creation.
      allow create: if signedIn()
        && request.resource.data.ownerUid == uid()
        && request.resource.data.members[uid()] == 'owner'
        && request.resource.data.memberUids.hasOnly([uid()]);

      // Update paths:
      //  - owner: full control (incl. member management)
      //  - editor: trip fields only, may NOT touch members/memberUids/ownerUid
      //  - anyone with a valid invite: self-join only
      allow update: if isOwner(tripId)
        || (canEdit(tripId)
            && request.resource.data.members == resource.data.members
            && request.resource.data.memberUids == resource.data.memberUids
            && request.resource.data.ownerUid == resource.data.ownerUid)
        || isSelfJoin(tripId);

      allow delete: if isOwner(tripId);

      // Sub-collections: read for members, write for editors/owners.
      match /{sub}/{docId} {
        allow read: if isMember(tripId);
        allow write: if canEdit(tripId);
      }
    }

    /* ── Trip invites ─────────────────────────────────────────────────── */
    match /tripInvites/{token} {
      // Any signed-in user can read an invite (to render the join screen).
      allow read: if signedIn();
      // Only a trip owner can create / revoke invites for their trip.
      allow create: if signedIn()
        && request.resource.data.createdByUid == uid()
        && isOwner(request.resource.data.tripId);
      allow update, delete: if signedIn() && isOwner(resource.data.tripId);
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
